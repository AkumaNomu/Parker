# Copy to %LOCALAPPDATA%\Parker\settings.env and restart Parker.
PARKER_OCR_LANG=eng
PARKER_OCR_PSM=6
PARKER_OCR_MODE=auto
PARKER_QR_AUTO_OPEN=1
PARKER_KEEP_OCR_CAPTURE=0
PARKER_RECORD_FPS=30
PARKER_COMPRESSION=balanced
PARKER_VIDEO_ENCODER=auto
